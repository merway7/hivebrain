---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const baseUrl = 'http://localhost:4321';

let learningCurves: any[] = [];
let ahaEntries: any[] = [];
let clusters: any[] = [];
let embeddingStatus: any = {};

try {
  const [curvesRes, ahaRes, clustersRes, embRes] = await Promise.all([
    fetch(`${baseUrl}/api/insights/learning-curves?limit=10`).then(r => r.json()).catch(() => []),
    fetch(`${baseUrl}/api/insights/aha?limit=8`).then(r => r.json()).catch(() => ({ entries: [] })),
    fetch(`${baseUrl}/api/insights/clusters`).then(r => r.json()).catch(() => ({ clusters: [] })),
    fetch(`${baseUrl}/api/embeddings/status`).then(r => r.json()).catch(() => ({})),
  ]);
  learningCurves = Array.isArray(curvesRes) ? curvesRes : [];
  ahaEntries = ahaRes?.entries || [];
  clusters = clustersRes?.clusters || [];
  embeddingStatus = embRes || {};
} catch { /* render with empty data */ }

let deadKnowledge: any[] = [];
let decayingKnowledge: any[] = [];
let coverageGaps: any = { underrepresented_tags: [], searched_but_empty: [] };
let searchChains: any[] = [];
let confidenceDistribution: any = { high: 0, medium: 0, low: 0, unscored: 0 };

try {
  const res = await fetch(`${import.meta.env.SITE || 'http://localhost:4321'}/api/insights/dead-knowledge?limit=10`);
  if (res.ok) deadKnowledge = await res.json();
} catch {}

try {
  const res = await fetch(`${import.meta.env.SITE || 'http://localhost:4321'}/api/insights/decay?limit=10`);
  if (res.ok) decayingKnowledge = await res.json();
} catch {}

try {
  const res = await fetch(`${import.meta.env.SITE || 'http://localhost:4321'}/api/insights/coverage-gaps`);
  if (res.ok) coverageGaps = await res.json();
} catch {}

try {
  const res = await fetch(`${import.meta.env.SITE || 'http://localhost:4321'}/api/insights/search-chains?limit=10`);
  if (res.ok) searchChains = await res.json();
} catch {}

try {
  const res = await fetch(`${import.meta.env.SITE || 'http://localhost:4321'}/api/insights/confidence`);
  if (res.ok) confidenceDistribution = await res.json();
} catch {}
---

<Layout title="Insights — HiveBrain">
  <div class="app">
    <Header />
    <main class="insights-page">
      <div class="page-header">
        <h1>Knowledge Intelligence</h1>
        <p class="subtitle">What the collective knows, doesn't know, and finds surprising</p>
      </div>

      <!-- System Health Bar -->
      <section class="health-bar">
        <div class="health-stat">
          <span class="health-label">Embedding Provider</span>
          <span class="health-value">{embeddingStatus.provider || 'none'}</span>
        </div>
        <div class="health-stat">
          <span class="health-label">Entries Embedded</span>
          <span class="health-value">{embeddingStatus.embedded_count || 0}</span>
        </div>
        <div class="health-stat">
          <span class="health-label">Total Entries</span>
          <span class="health-value">{embeddingStatus.total_entries || 0}</span>
        </div>
        {embeddingStatus.embedded_count > 0 && embeddingStatus.total_entries > 0 && (
          <div class="health-stat">
            <span class="health-label">Coverage</span>
            <div class="health-bar-visual">
              <div class="health-bar-fill" style={`width: ${Math.round((embeddingStatus.embedded_count / embeddingStatus.total_entries) * 100)}%`}></div>
            </div>
            <span class="health-value">{Math.round((embeddingStatus.embedded_count / embeddingStatus.total_entries) * 100)}%</span>
          </div>
        )}
      </section>

      <!-- Learning Curves -->
      <section class="section">
        <h2>Learning Curves</h2>
        <p class="section-desc">Topics where search frequency is declining = knowledge the collective has internalized. Rising = emerging problems.</p>

        {learningCurves.length === 0 ? (
          <div class="empty-state">No search trend data yet. Trends build up as agents search HiveBrain.</div>
        ) : (
          <div class="curves-grid">
            {learningCurves.map((curve: any) => (
              <div class={`curve-card ${curve.is_declining ? 'learned' : ''}`}>
                <div class="curve-header">
                  <span class="curve-tag">{curve.tag}</span>
                  <span class={`curve-status ${curve.is_declining ? 'status-learned' : 'status-active'}`}>
                    {curve.is_declining ? 'LEARNED' : 'ACTIVE'}
                  </span>
                </div>
                <div class="curve-stats">
                  <span>{curve.total_searches} searches</span>
                </div>
                <!-- Simple sparkline using CSS -->
                <div class="sparkline">
                  {(curve.trend || []).slice(-14).map((point: any, i: number) => {
                    const recentTrend = (curve.trend || []).slice(-14);
                    const max = Math.max(...recentTrend.map((p: any) => p.search_count), 1);
                    const height = (point.search_count / max) * 100;
                    return <div class="spark-bar" style={`height: ${Math.max(2, height)}%; opacity: ${0.4 + (i / 14) * 0.6}`} />;
                  })}
                </div>
              </div>
            ))}
          </div>
        )}
      </section>

      <!-- Aha Feed -->
      <section class="section">
        <h2>The "Aha" Feed</h2>
        <p class="section-desc">The most surprising knowledge -- entries that agents didn't expect to be useful but turned out to be invaluable.</p>

        {ahaEntries.length === 0 ? (
          <div class="empty-state">Not enough usage data yet. The aha feed populates as entries get used and voted on.</div>
        ) : (
          <div class="aha-list">
            {ahaEntries.map((entry: any) => (
              <a href={`/entry/${entry.id}`} class="aha-card">
                <div class="aha-meta">
                  <span class="aha-category">{entry.category}</span>
                  <span class="aha-severity">{entry.severity}</span>
                  {entry.success_rate != null && (
                    <span class="aha-success">{Math.round(entry.success_rate * 100)}% success</span>
                  )}
                </div>
                <h3 class="aha-title">{entry.title}</h3>
                <p class="aha-snippet">{entry.problem_snippet}</p>
                <div class="aha-stats">
                  <span>Used {entry.usage_count}x</span>
                  <span>{entry.upvotes > 0 ? `+${entry.upvotes}` : entry.upvotes} votes</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </section>

      <!-- Knowledge Clusters -->
      <section class="section">
        <h2>Knowledge Clusters</h2>
        <p class="section-desc">Groups of entries covering similar topics -- candidates for distillation into canonical super-entries.</p>

        {clusters.length === 0 ? (
          <div class="empty-state">Not enough entries to form clusters yet.</div>
        ) : (
          <div class="clusters-grid">
            {clusters.map((cluster: any) => (
              <div class="cluster-card">
                <div class="cluster-count">{cluster.entry_count}</div>
                <div class="cluster-info">
                  <h4>{cluster.representative_title}</h4>
                  <div class="cluster-tags">
                    {(cluster.tags || []).slice(0, 5).map((tag: string) => (
                      <span class="cluster-tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </section>

      <!-- Confidence Distribution -->
      <section class="insight-section">
        <h2>Confidence Calibration</h2>
        <p class="section-desc">How confident are we in each entry's correctness?</p>
        <div class="confidence-bars">
          <div class="conf-bar">
            <span class="conf-label">High (&gt;70%)</span>
            <div class="conf-track">
              <div class="conf-fill conf-high" style={`width: ${Math.min(100, (confidenceDistribution.high / Math.max(1, confidenceDistribution.high + confidenceDistribution.medium + confidenceDistribution.low + confidenceDistribution.unscored)) * 100)}%`}></div>
            </div>
            <span class="conf-count">{confidenceDistribution.high}</span>
          </div>
          <div class="conf-bar">
            <span class="conf-label">Medium (40-70%)</span>
            <div class="conf-track">
              <div class="conf-fill conf-medium" style={`width: ${Math.min(100, (confidenceDistribution.medium / Math.max(1, confidenceDistribution.high + confidenceDistribution.medium + confidenceDistribution.low + confidenceDistribution.unscored)) * 100)}%`}></div>
            </div>
            <span class="conf-count">{confidenceDistribution.medium}</span>
          </div>
          <div class="conf-bar">
            <span class="conf-label">Low (&lt;40%)</span>
            <div class="conf-track">
              <div class="conf-fill conf-low" style={`width: ${Math.min(100, (confidenceDistribution.low / Math.max(1, confidenceDistribution.high + confidenceDistribution.medium + confidenceDistribution.low + confidenceDistribution.unscored)) * 100)}%`}></div>
            </div>
            <span class="conf-count">{confidenceDistribution.low}</span>
          </div>
          <div class="conf-bar">
            <span class="conf-label">Unscored</span>
            <div class="conf-track">
              <div class="conf-fill conf-unscored" style={`width: ${Math.min(100, (confidenceDistribution.unscored / Math.max(1, confidenceDistribution.high + confidenceDistribution.medium + confidenceDistribution.low + confidenceDistribution.unscored)) * 100)}%`}></div>
            </div>
            <span class="conf-count">{confidenceDistribution.unscored}</span>
          </div>
        </div>
      </section>

      <!-- Dead Knowledge -->
      <section class="insight-section">
        <h2>Dead Knowledge</h2>
        <p class="section-desc">Entries that exist but were never found by search — invisible knowledge.</p>
        {deadKnowledge.length === 0 ? (
          <p class="empty-state">No dead knowledge detected — all entries are being found!</p>
        ) : (
          <div class="dead-list">
            {deadKnowledge.map((e: any) => (
              <a href={`/entry/${e.id}`} class="dead-entry">
                <span class="dead-title">{e.title}</span>
                <span class="dead-meta">{e.category} · created {new Date(e.created_at * 1000).toLocaleDateString()}</span>
              </a>
            ))}
          </div>
        )}
      </section>

      <!-- Decaying Knowledge -->
      <section class="insight-section">
        <h2>Decaying Knowledge</h2>
        <p class="section-desc">Once-popular entries that stopped being used — verify or retire them.</p>
        {decayingKnowledge.length === 0 ? (
          <p class="empty-state">No decaying entries detected.</p>
        ) : (
          <div class="decay-list">
            {decayingKnowledge.map((e: any) => (
              <a href={`/entry/${e.id}`} class="decay-entry">
                <span class="decay-title">{e.title}</span>
                <div class="decay-bar-container">
                  <span class="decay-label">Peak: {e.peak_usage}</span>
                  <div class="decay-bar">
                    <div class="decay-fill" style={`width: ${Math.max(5, (1 - e.decay_rate) * 100)}%`}></div>
                  </div>
                  <span class="decay-label">Now: {e.recent_usage}</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </section>

      <!-- Coverage Gaps -->
      <section class="insight-section">
        <h2>Coverage Gaps</h2>
        <p class="section-desc">Topics frequently searched but poorly covered — knowledge blind spots.</p>
        <div class="gaps-grid">
          {coverageGaps.searched_but_empty?.length > 0 && (
            <div class="gap-section">
              <h3>Searches With No Results</h3>
              {coverageGaps.searched_but_empty.map((s: any) => (
                <div class="gap-item">
                  <span class="gap-query">"{s.query}"</span>
                  <span class="gap-count">{s.search_count}x</span>
                </div>
              ))}
            </div>
          )}
          {coverageGaps.underrepresented_tags?.length > 0 && (
            <div class="gap-section">
              <h3>Underrepresented Tags</h3>
              {coverageGaps.underrepresented_tags.map((t: any) => (
                <div class="gap-item">
                  <span class="gap-tag">{t.tag}</span>
                  <span class="gap-detail">{t.entry_count} entries / {t.search_count} searches</span>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>

      <!-- Search Chains -->
      <section class="insight-section">
        <h2>Search Chains</h2>
        <p class="section-desc">Common sequential search patterns — how agents actually debug.</p>
        {searchChains.length === 0 ? (
          <p class="empty-state">No search chains recorded yet. Chains are built from sequential agent searches.</p>
        ) : (
          <div class="chains-list">
            {searchChains.map((chain: any) => (
              <div class="chain">
                <div class="chain-queries">
                  {chain.queries.map((q: string, i: number) => (
                    <span class="chain-step">
                      {i > 0 && <span class="chain-arrow">&rarr;</span>}
                      <span class="chain-query">{q}</span>
                    </span>
                  ))}
                </div>
                <span class="chain-length">{chain.length} steps</span>
              </div>
            ))}
          </div>
        )}
      </section>

    </main>
  </div>
</Layout>

<style>
  .insights-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .page-header {
    margin-bottom: 32px;
  }

  .page-header h1 {
    font-size: 28px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 8px;
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-muted);
    margin: 0;
  }

  /* Health Bar */
  .health-bar {
    display: flex;
    gap: 24px;
    padding: 16px 20px;
    background: var(--bg-overlay);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .health-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .health-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .health-value {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
  }

  .health-bar-visual {
    width: 80px;
    height: 6px;
    background: var(--bg-surface);
    border-radius: 3px;
    overflow: hidden;
  }

  .health-bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.3s ease;
  }

  /* Sections */
  .section {
    margin-bottom: 40px;
  }

  .section h2 {
    font-size: 20px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 6px;
  }

  .section-desc {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    margin: 0 0 20px;
    line-height: 1.5;
  }

  .empty-state {
    padding: 32px;
    text-align: center;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--bg-overlay);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  /* Learning Curves */
  .curves-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }

  .curve-card {
    background: var(--bg-overlay);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px;
    transition: border-color 0.15s ease;
  }

  .curve-card:hover {
    border-color: var(--border-hover);
  }

  .curve-card.learned {
    border-color: rgba(74, 222, 128, 0.3);
  }

  .curve-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .curve-tag {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .curve-status {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 600;
  }

  .status-learned {
    background: rgba(74, 222, 128, 0.15);
    color: #4ade80;
  }

  .status-active {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
  }

  .curve-stats {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .sparkline {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 32px;
  }

  .spark-bar {
    flex: 1;
    background: var(--accent);
    border-radius: 2px 2px 0 0;
    min-height: 2px;
  }

  .curve-card.learned .spark-bar {
    background: #4ade80;
  }

  /* Aha Feed */
  .aha-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .aha-card {
    display: block;
    background: var(--bg-overlay);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px 20px;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .aha-card:hover {
    border-color: var(--accent);
    background: var(--bg-hover);
  }

  .aha-meta {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
  }

  .aha-category, .aha-severity, .aha-success {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--bg-surface);
    color: var(--text-muted);
  }

  .aha-success {
    background: rgba(74, 222, 128, 0.15);
    color: #4ade80;
  }

  .aha-title {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 6px;
  }

  .aha-snippet {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    margin: 0 0 10px;
    line-height: 1.5;
  }

  .aha-stats {
    display: flex;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  /* Clusters */
  .clusters-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cluster-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--bg-overlay);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 14px 20px;
  }

  .cluster-count {
    font-family: var(--font-mono);
    font-size: 24px;
    font-weight: 700;
    color: var(--accent);
    min-width: 48px;
    text-align: center;
  }

  .cluster-info h4 {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 6px;
  }

  .cluster-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .cluster-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--bg-surface);
    color: var(--text-muted);
  }

  /* Insight sections */
  .insight-section {
    margin-bottom: 40px;
  }
  .insight-section h2 {
    font-size: 20px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 6px;
  }

  /* Confidence bars */
  .confidence-bars {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .conf-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .conf-label {
    min-width: 130px;
    font-size: 0.9rem;
    color: var(--text-muted, #94a3b8);
  }
  .conf-track {
    flex: 1;
    height: 24px;
    background: var(--bg-surface, #1e293b);
    border-radius: 6px;
    overflow: hidden;
  }
  .conf-fill {
    height: 100%;
    border-radius: 6px;
    transition: width 0.5s ease;
  }
  .conf-high { background: #22c55e; }
  .conf-medium { background: #eab308; }
  .conf-low { background: #ef4444; }
  .conf-unscored { background: #475569; }
  .conf-count {
    min-width: 50px;
    text-align: right;
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* Dead knowledge */
  .dead-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .dead-entry {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: var(--bg-overlay, #1e293b);
    border-radius: 8px;
    border-left: 3px solid #ef4444;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .dead-entry:hover { background: var(--bg-hover, #334155); }
  .dead-title { font-weight: 500; }
  .dead-meta { font-size: 0.8rem; color: var(--text-muted, #94a3b8); }

  /* Decaying knowledge */
  .decay-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .decay-entry {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--bg-overlay, #1e293b);
    border-radius: 8px;
    border-left: 3px solid #eab308;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .decay-entry:hover { background: var(--bg-hover, #334155); }
  .decay-title { font-weight: 500; }
  .decay-bar-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .decay-label {
    font-size: 0.8rem;
    color: var(--text-muted, #94a3b8);
    min-width: 60px;
  }
  .decay-bar {
    flex: 1;
    height: 8px;
    background: var(--bg-surface, #334155);
    border-radius: 4px;
    overflow: hidden;
  }
  .decay-fill {
    height: 100%;
    background: linear-gradient(90deg, #ef4444, #eab308);
    border-radius: 4px;
  }

  /* Coverage gaps */
  .gaps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .gap-section h3 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--text-muted, #94a3b8);
  }
  .gap-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border, #334155);
  }
  .gap-query {
    font-style: italic;
    color: #f97316;
  }
  .gap-tag {
    padding: 0.2rem 0.6rem;
    background: var(--bg-surface, #334155);
    border-radius: 4px;
    font-size: 0.85rem;
  }
  .gap-count, .gap-detail {
    font-size: 0.8rem;
    color: var(--text-muted, #94a3b8);
  }

  /* Search chains */
  .chains-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .chain {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
